# --- Vault data: NEVER commit. The DB holds ciphertext, but the salt +
# --- metadata still don't belong in git history.
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.nmpbak

# --- Plaintext import material: never commit, delete after import.
passwords.txt
notepad*.txt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Build artifacts (the spec, installer script, and make_icon.py stay tracked)
/dist/
/build/_work/
/build/_build.log
/release/
*.spec.bak

# Tooling
.pytest_cache/
.DS_Store
