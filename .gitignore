# --- Vault data: NEVER commit. The DB holds ciphertext, but the salt +
# --- metadata still don't belong in git history.
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.nmpbak

# --- Plaintext import material: never commit, delete after import.
passwords.txt
notepad*.txt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Generated by build/NoMorePwn.spec at build time — never commit a stale version.
nomorepwn_app/_build_info.py

# Build artifacts (the spec, installer script, and make_icon.py stay tracked)
/dist/
/build/_work/
/build/_build.log
/release/
*.spec.bak

# Tooling
.pytest_cache/
.DS_Store

# Browser extension (Node dev tooling only; the extension itself ships as source)
node_modules/
package-lock.json

# The extension's signing key. The PUBLIC half lives in manifest.json ("key")
# and pins the extension ID; this private half is only needed to pack a .crx.
extension/.keys/
